{
  "name": "cvx-junior-golf",
  "version": "1.4.0",
  "description": "Website for the Charlevoix Junior Golf League.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "payload migrate && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=6144\" next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbo",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "migrate:create": "cross-env payload migrate:create",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/email-nodemailer": "3.84.1",
    "@payloadcms/email-resend": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-import-export": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-sentry": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/plugin-stripe": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@sentry/nextjs": "8.55.0",
    "@tanstack/react-form": "1.27.7",
    "@vis.gl/react-google-maps": "^1.8.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-fade": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "geist": "^1.7.0",
    "jsonwebtoken": "9.0.3",
    "lucide-react": "1.11.0",
    "motion": "12.38.0",
    "next": "16.2.4",
    "next-sitemap": "^4.2.3",
    "payload": "3.84.1",
    "react": "19.2.5",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.5",
    "require-in-the-middle": "7.5.2",
    "sharp": "0.34.5",
    "stripe": "17.0.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "16.2.4",
    "@payloadcms/eslint-config": "3.28.0",
    "@tailwindcss/postcss": "4.1.13",
    "@tailwindcss/typography": "0.5.16",
    "@types/escape-html": "^1.0.4",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "22.15.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.30.1",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
